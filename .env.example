# Poster files older than this (seconds) are deleted during cleanup. Default: 3600 (1 hour).
POSTER_TTL_SECONDS=3600

# Max concurrent poster renders (limits load on the shared Chromium instance). Default: 2.
MAX_CONCURRENT_RENDERS=2

# Base URL Playwright uses to open internal `/render/<id>` routes before screenshot. Must match how the app is reachable from the Node process (inside Docker, same container: http://localhost:3000). Default: http://localhost:3000
INTERNAL_RENDER_HOST=http://localhost:3000

# GitHub (or other) URL for the "xxlemon" link in the poster brand footer. Default: https://github.com/0xNMLSS/shotweet
SHOTWEET_BRAND_REPO_URL=https://github.com/0xNMLSS/shotweet
